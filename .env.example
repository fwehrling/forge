# FORGE Memory — Environment Variables (optional overrides)
# Copy to your shell profile (~/.zshrc, ~/.bashrc) or Claude Code settings.json env block.
# All values below are the defaults — uncomment and change only what you need.

# --- Search tuning ---
# FORGE_VECTOR_WEIGHT=0.7        # Weight for vector similarity (0.0-1.0)
# FORGE_FTS_WEIGHT=0.3           # Weight for FTS5 keyword matching (0.0-1.0)
# FORGE_SEARCH_LIMIT=5           # Max results per search
# FORGE_SEARCH_THRESHOLD=0.3     # Minimum score to include (0.0-1.0)

# --- Chunking ---
# FORGE_CHUNK_SIZE=400            # Tokens per chunk
# FORGE_CHUNK_OVERLAP=80          # Overlap tokens between chunks
